                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>

                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isolement d'un segment de deux îles" userData="7" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isolement d'un segment de trois îles" userData="8" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isolement lorsqu'un segment se connecte à une île" userData="9" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isolement lorsqu'un segment se connecte à un autre segment" userData="10" wrapText="true" />
                        
                        <Label text="TECHNIQUES AVANCÉES">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isoler un segment en bloquant un pont" userData="11" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isoler un segment en ajoutant un pont" userData="12" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Isoler une île avec des ponts" userData="13" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Créer des conflits de connexion entre les ponts" userData="14" wrapText="true" />
