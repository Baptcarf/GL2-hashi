                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Button>
                        <Label text="TECHNIQUE DU COIN">
                           <font>
                              <Font name="System Bold" size="20.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <TextArea fx:id="mainContentArea" editable="false" prefHeight="200.0" prefWidth="551.0" text="Sélectionnez une technique sur la droite..." wrapText="true" VBox.vgrow="ALWAYS">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </TextArea>
                  
                  <HBox fx:id="imageContainer" alignment="CENTER" prefHeight="293.0" prefWidth="551.0" spacing="10.0" style="-fx-border-color: black; -fx-border-width: 2; -fx-border-style: solid;" VBox.vgrow="ALWAYS" />
