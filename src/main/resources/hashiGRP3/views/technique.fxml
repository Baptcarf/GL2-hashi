                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Cas particulier de 4 sur le côté" userData="5" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Cas particulier de 6 au milieu" userData="6" wrapText="true" />

