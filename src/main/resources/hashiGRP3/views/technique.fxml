               <content>
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="TECHNIQUES DE BASE">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Iles avec 4 dans le coin, 6 sur le côté et 8 au milieu" userData="1" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Îles avec un seul voisin" userData="2" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleTechniqueClick" text="Iles avec 3 dans le coin, 5 sur le côté et 7 au milieu" userData="3" wrapText="true" />
