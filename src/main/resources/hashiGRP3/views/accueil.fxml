<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.HBox?>


<VBox alignment="TOP_CENTER" spacing="60.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hashiGRP3.Controller.ManageController"
      style="-fx-padding: 50 20 20 20;">

    <Label text="Hashi" styleClass="titre">
        <font><Font size="41.0"/></font>
    </Label>


    <Region prefHeight="30.0"/> 

    <VBox alignment = "TOP_CENTER" spacing="20">
        <Button text="Jouer" onAction="#changeScene" userData="selectGrille" style="-fx-pref-width: 200;">
            <font><Font size="25.0"/></font>
        </Button>
        <Button text="Tutoriel" style="-fx-pref-width: 200;">
            <font><Font size="25.0"/></font>
        </Button>
        <Button text="Option" style="-fx-pref-width: 200;" onAction="#changeScene" userData="option">
            <font><Font size="25.0"/></font>
        </Button>
        <Button text="Quitter" style="-fx-pref-width: 200;" onAction="#quitApp">
            <font><Font size="25.0"/></font>
        </Button>
    </VBox>

    <!-- Region flexible pour pousser le bouton Technique en bas -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Bouton Technique en bas à gauche -->
    <HBox alignment="BOTTOM_RIGHT" prefWidth="600.0" style="-fx-padding:0 0 20 20;">
        <Button text="Technique" onAction="#changeScene" userData="technique">
            <font><Font size="12.0"/></font>
        </Button>
    </HBox>
</VBox>