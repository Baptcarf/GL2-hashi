<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hashiGRP3.Controller.OptionController">
   <children>
      <Label alignment="CENTER" styleClass="titre" text="Options">
         <font>
            <Font size="41.0" />
         </font>
      </Label>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
         <children>
            <Label text="Plein écran :" />
            <CheckBox fx:id="fullCheck" alignment="TOP_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" onAction="#on_fullscreen_button_pressed" />
         </children>
      </HBox>
      <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#changeScene" text="Retour" userData="accueil" />
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <VBox.margin>
            <Insets top="60.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
